# Build artifacts
/target/
Cargo.lock
.DS_Store

# Runtime config — generated per-repo, not part of the tool
synth.yaml
.reposynth/

# All generated data — pass directly to training machine, not tracked
data/holdout/*
data/training/*
handoff/

# Temporary files received from training machine
tmp/

# Data files are never tracked (pass directly to training machine)
*.jsonl

# Eval manifests change every cycle — not tracked
evals/*_manifest.yaml
